{
  "Description.ja": "\u30C7\u30C3\u30B5\u30F3\u7528\u30B9\u30B1\u30C3\u30C1\u30D6\u30C3\u30AF\u306E\u3088\u3046\u306A\u3001\u3084\u3084\u6697\u3081\u306E\u30A6\u30A9\u30FC\u30E0\u30B0\u30EC\u30FC\u306B\u30C1\u30E3\u30B3\u30FC\u30EB\u304C\u6620\u3048\u308B\u30C6\u30FC\u30DE",
