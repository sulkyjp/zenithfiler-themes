  "Description.zh-TW": "\u4EE4\u4EBA\u806F\u60F3\u5230\u9187\u539A\u7D05\u9152\u7684\u9AD8\u7D1A\u4E3B\u984C\uFF0C\u6FC3\u90C1\u52C3\u6839\u5730\u7D05\u6620\u896F\u5FAE\u7D05\u7684\u9ED1\u8272",
