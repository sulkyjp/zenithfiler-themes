{
  "Description.ja": "\u6DF1\u7D05\u306E\u30EF\u30A4\u30F3\u3092\u601D\u308F\u305B\u308B\u3001\u5FAE\u8D64\u306E\u6F06\u9ED2\u306B\u6C88\u3093\u3060\u30D0\u30FC\u30AC\u30F3\u30C7\u30A3\u304C\u6620\u3048\u308B\u30D7\u30EC\u30DF\u30A2\u30E0\u30C6\u30FC\u30DE",
