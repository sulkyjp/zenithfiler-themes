{
  "Description.ja": "P4\u30D6\u30EB\u30FC\u86CD\u5149\u4F53\u306ECRT\u30E2\u30CB\u30BF\u30FC\u3092\u518D\u73FE\u3057\u305F\u3001\u9752\u3044\u71D0\u5149\u304C\u6D6E\u304B\u3076\u30EC\u30C8\u30ED\u30C6\u30FC\u30DE",
  "Description.en": "A retro theme recreating a P4 blue phosphor CRT monitor, with blue phosphorescence floating in darkness",
  "Description.zh-CN": "\u518D\u73B0P4\u84DD\u8272\u8367\u5149CRT\u663E\u793A\u5668\u7684\u590D\u53E4\u4E3B\u9898\uFF0C\u84DD\u8272\u78F7\u5149\u5728\u9ED1\u6697\u4E2D\u6F02\u6D6E",
  "Description.zh-TW": "\u518D\u73FEP4\u85CD\u8272\u87A2\u5149CRT\u986F\u793A\u5668\u7684\u5FA9\u53E4\u4E3B\u984C\uFF0C\u85CD\u8272\u78F7\u5149\u5728\u9ED1\u6697\u4E2D\u6F02\u6D6E",
  "Description.ko-KR": "P4 \uBE14\uB8E8 \uD615\uAD11\uCCB4 CRT \uBAA8\uB2C8\uD130\uB97C \uC7AC\uD604\uD55C \uB808\uD2B8\uB85C \uD14C\uB9C8, \uC5B4\uB460 \uC18D\uC5D0 \uD30C\uB780 \uC778\uAD11\uC774 \uB5A0\uB2E4\uB2C8\uB294",
