{
  "Description.ja": "\u30E1\u30ED\u30F3\u306E\u679C\u8089\u3092\u601D\u308F\u305B\u308B\u67D4\u3089\u304B\u306A\u9EC4\u7DD1\u306B\u3001\u30AA\u30EA\u30FC\u30D6\u30B0\u30EA\u30FC\u30F3\u304C\u6620\u3048\u308B\u30C6\u30FC\u30DE",
