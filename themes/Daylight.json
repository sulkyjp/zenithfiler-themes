{
  "Description.ja": "\u81EA\u7136\u5149\u306E\u3088\u3046\u306A\u67D4\u3089\u304B\u3055\u3068\u5B9F\u7528\u6027\u3092\u4E21\u7ACB\u3057\u305F\u3001\u30CB\u30E5\u30FC\u30C8\u30E9\u30EB\u30B0\u30EC\u30FC\u57FA\u8ABF\u306E\u30C6\u30FC\u30DE",
