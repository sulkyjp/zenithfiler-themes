  "Description.ru": "\u041C\u044F\u0442\u043D\u043E-\u0437\u0435\u043B\u0451\u043D\u044B\u0439 \u0438 \u0447\u0438\u0441\u0442\u044B\u0439 \u0431\u0435\u043B\u044B\u0439 \u2014 \u0441\u0432\u0435\u0436\u0438\u0439, \u043B\u0451\u0433\u043A\u0438\u0439 \u0438 \u0436\u0438\u0432\u043E\u0439 \u0441\u0442\u0438\u043B\u044C \u0441 \u0447\u0438\u0441\u0442\u043E\u0439 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u044C\u044E",
