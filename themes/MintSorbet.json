{
  "Description.ja": "\u30DF\u30F3\u30C8\u30B0\u30EA\u30FC\u30F3\u3068\u30D4\u30E5\u30A2\u30DB\u30EF\u30A4\u30C8\u3002\u6E05\u6F54\u611F\u3042\u3075\u308C\u308B\u3001\u8EFD\u3084\u304B\u3067\u30A2\u30AF\u30C6\u30A3\u30D6\u306A\u30B9\u30BF\u30A4\u30EB\uFF08\u5973\u6027\u5411\u3051\uFF09",
  "Description.en": "Mint green and pure white \u2014 a fresh, light, and lively style full of clean elegance",
  "Description.zh-CN": "\u8584\u8377\u7EFF\u4E0E\u7EAF\u767D\u2014\u2014\u6E05\u65B0\u8F7B\u5FEB\u3001\u5145\u6EE1\u6D01\u51C0\u4F18\u96C5\u7684\u6D3B\u6CFC\u98CE\u683C",
  "Description.zh-TW": "\u8584\u8377\u7DA0\u8207\u7D14\u767D\u2014\u2014\u6E05\u65B0\u8F15\u5FEB\u3001\u5145\u6EFF\u6F54\u6DE8\u512A\u96C5\u7684\u6D3B\u6F51\u98A8\u683C",
  "Description.ko-KR": "\uBBFC\uD2B8 \uADF8\uB9B0\uACFC \uC21C\uBC31 \u2014 \uC0B0\uB73B\uD558\uACE0 \uAC00\uBCCD\uACE0 \uAE54\uB054\uD55C \uC6B0\uC544\uD568\uC774 \uB118\uCE58\uB294 \uACBD\uCF8C\uD55C \uC2A4\uD0C0\uC77C",
