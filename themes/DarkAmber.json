{
  "Description.ja": "\u7425\u73C0\u306E\u6B8B\u5149\u306E\u3088\u3046\u306A\u6696\u8272\u306E\u6697\u8272\u306B\u3001\u63A7\u3048\u3081\u306A\u30A2\u30F3\u30D0\u30FC\u304C\u9759\u304B\u306B\u706F\u308B\u30C6\u30FC\u30DE",
