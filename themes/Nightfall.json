  "Description.ru": "\u0422\u0438\u0445\u0430\u044F \u0442\u0435\u043C\u0430 \u0441 \u043C\u044F\u0433\u043A\u0438\u043C \u043B\u0430\u0432\u0430\u043D\u0434\u043E\u0432\u043E-\u0441\u0438\u043D\u0438\u043C \u043D\u0430 \u0444\u043E\u043D\u0435 \u0441\u0443\u043C\u0435\u0440\u0435\u0447\u043D\u043E\u0439, \u0441 \u043F\u0443\u0440\u043F\u0443\u0440\u043D\u044B\u043C \u043E\u0442\u0442\u0435\u043D\u043A\u043E\u043C, \u0442\u0435\u043C\u043D\u043E\u0442\u044B",
