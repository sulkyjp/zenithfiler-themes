{
  "Description.ja": "\u591C\u306E\u5E33\u306E\u3088\u3046\u306A\u5FAE\u7D2B\u306E\u6697\u8272\u306B\u3001\u63A7\u3048\u3081\u306A\u30E9\u30D9\u30F3\u30C0\u30FC\u30D6\u30EB\u30FC\u304C\u5DEE\u3059\u9759\u304B\u306A\u30C6\u30FC\u30DE",
  "Description.en": "A quiet theme with subtle lavender blue against a twilight-like purple-tinged darkness",
  "Description.zh-CN": "\u5B81\u9759\u4E3B\u9898\uFF0C\u6DE1\u85B0\u8863\u8349\u84DD\u6620\u886C\u7740\u9EC4\u660F\u822C\u7684\u7D2B\u8272\u6697\u8C03",
  "Description.zh-TW": "\u5BE7\u975C\u4E3B\u984C\uFF0C\u6DE1\u85B0\u8863\u8349\u85CD\u6620\u896F\u8457\u9EC3\u660F\u822C\u7684\u7D2B\u8272\u6697\u8ABF",
