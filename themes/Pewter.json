  "Description.ru": "\u0418\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u0438\u0437 \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u043E\u0439 \u0441\u0442\u0430\u043B\u0438. \u0425\u043E\u043B\u043E\u0434\u043D\u043E-\u0441\u0435\u0440\u044B\u0439 \u0444\u043E\u043D \u0441\u0440\u0435\u0434\u043D\u0435\u0439 \u0441\u0432\u0435\u0442\u043B\u043E\u0442\u044B \u0441 \u043F\u0430\u043D\u0435\u043B\u044C\u044E \u0438\u0437 \u0448\u043B\u0438\u0444\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u0441\u0442\u0430\u043B\u0438 \u0438 \u0430\u043A\u0446\u0435\u043D\u0442\u0430\u043C\u0438 \u043E\u0440\u0443\u0436\u0435\u0439\u043D\u043E\u0433\u043E \u043C\u0435\u0442\u0430\u043B\u043B\u0430",
