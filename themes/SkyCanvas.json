{
  "Description.ja": "\u6674\u308C\u305F\u7A7A\u3092\u5199\u3057\u305F\u3088\u3046\u306A\u6DE1\u3044\u6C34\u8272\u306B\u3001\u843D\u3061\u7740\u3044\u305F\u30A4\u30F3\u30C7\u30A3\u30B4\u304C\u6620\u3048\u308B\u30C6\u30FC\u30DE",
  "Description.en": "A pale sky blue theme like a clear sky photograph, accented with calm indigo",
  "Description.zh-CN": "\u5982\u6674\u7A7A\u7167\u7247\u822C\u7684\u6DE1\u5929\u84DD\u4E3B\u9898\uFF0C\u4EE5\u6C89\u9759\u7684\u975B\u84DD\u70B9\u7F00",
  "Description.zh-TW": "\u5982\u6674\u7A7A\u7167\u7247\u822C\u7684\u6DE1\u5929\u85CD\u4E3B\u984C\uFF0C\u4EE5\u6C89\u975C\u7684\u975B\u85CD\u9EDE\u7DB4",
  "Description.ko-KR": "\uB9D1\uC740 \uD558\uB298 \uC0AC\uC9C4 \uAC19\uC740 \uC605\uC740 \uC2A4\uCE74\uC774 \uBE14\uB8E8 \uD14C\uB9C8\uC5D0 \uCC28\uBD84\uD55C \uC778\uB514\uACE0 \uC561\uC13C\uD2B8",
