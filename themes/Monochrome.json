  // ============================================================

  // テーマのメタデータ
  "Description.ja": "色によるバイアスを排除し、データの形だけに集中するための作業環境",
  "Description.en": "A workspace that eliminates color bias so you can focus purely on the shape of data",
  "Description.zh-CN": "消除色彩偏见的工作空间，让你纯粹专注于数据的形态",
  "Description.zh-TW": "消除色彩偏見的工作空間，讓你純粹專注於資料的形態",
  "Description.ko-KR": "색상 편향을 제거하여 데이터의 형태에 순수하게 집중할 수 있는 작업 공간",
  "Description.de": "Ein Arbeitsbereich, der Farbablenkung eliminiert, damit Sie sich rein auf die Form der Daten konzentrieren können",
  "Description.es": "Un espacio de trabajo que elimina el sesgo cromático para enfocarse puramente en la forma de los datos",
  "Description.fr": "Un espace de travail éliminant le biais chromatique pour se concentrer purement sur la forme des données",
  "Description.ru": "Рабочее пространство без цветовых отвлечений, позволяющее сосредоточиться на форме данных",
  "Description.pt": "Um espaço de trabalho que elimina viés cromático para focar puramente na forma dos dados",
  "Author": "KAKASAKA",
  "Category": "Professional",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#121212",                      // メイン背景色
