{
  "Description.ja": "\u8272\u306B\u3088\u308B\u30D0\u30A4\u30A2\u30B9\u3092\u6392\u9664\u3057\u3001\u30C7\u30FC\u30BF\u306E\u5F62\u3060\u3051\u306B\u96C6\u4E2D\u3059\u308B\u305F\u3081\u306E\u4F5C\u696D\u74B0\u5883",
  "Description.en": "A workspace that eliminates color bias so you can focus purely on the shape of data",
  "Description.zh-CN": "\u6D88\u9664\u8272\u5F69\u504F\u89C1\u7684\u5DE5\u4F5C\u7A7A\u95F4\uFF0C\u8BA9\u4F60\u7EAF\u7CB9\u4E13\u6CE8\u4E8E\u6570\u636E\u7684\u5F62\u6001",
  "Description.zh-TW": "\u6D88\u9664\u8272\u5F69\u504F\u898B\u7684\u5DE5\u4F5C\u7A7A\u9593\uFF0C\u8B93\u4F60\u7D14\u7CB9\u5C08\u6CE8\u65BC\u8CC7\u6599\u7684\u5F62\u614B",
  "Description.ko-KR": "\uC0C9\uC0C1 \uD3B8\uD5A5\uC744 \uC81C\uAC70\uD558\uC5EC \uB370\uC774\uD130\uC758 \uD615\uD0DC\uC5D0 \uC21C\uC218\uD558\uAC8C \uC9D1\uC911\uD560 \uC218 \uC788\uB294 \uC791\uC5C5 \uACF5\uAC04",
