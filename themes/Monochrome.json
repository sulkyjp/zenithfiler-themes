  "Description.ru": "\u0420\u0430\u0431\u043E\u0447\u0435\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0431\u0435\u0437 \u0446\u0432\u0435\u0442\u043E\u0432\u044B\u0445 \u043E\u0442\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0439, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0435\u0435 \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u0442\u044C\u0441\u044F \u043D\u0430 \u0444\u043E\u0440\u043C\u0435 \u0434\u0430\u043D\u043D\u044B\u0445",
