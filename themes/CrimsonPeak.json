{
  // ============================================================
  //  Zenith Filer Theme Configuration: CrimsonPeak (Premium)
  //  コンセプト：濃いグレーと鮮烈なクリムゾンの対比。決断力を促すエグゼクティブ・ダーク
  //  改善点：ボタン・フォームの立体化、文字コントラストの最適化、履歴ページの可読性向上
  // ============================================================

  "Description.ja": "濃いグレーと鮮烈なクリムゾンの対比。決断力を促すエグゼクティブ・ダーク",
  "Description.en": "A bold contrast of dark gray and vivid crimson — an executive dark theme that inspires decisiveness",
  "Description.zh-CN": "深灰与鲜红的大胆对比——激发决断力的高管暗色主题",
  "Description.zh-TW": "深灰與鮮紅的大膽對比——激發決斷力的高階暗色主題",
  "Description.ko-KR": "다크 그레이와 선명한 크림슨의 대담한 대비 — 결단력을 불어넣는 이그제큐티브 다크 테마",
  "Description.de": "Ein mutiger Kontrast aus Dunkelgrau und leuchtendem Karmesin — ein exekutives dunkles Thema, das Entschlossenheit weckt",
  "Description.es": "Un audaz contraste de gris oscuro y carmesí vívido — un tema oscuro ejecutivo que inspira determinación",
  "Description.fr": "Un contraste audacieux de gris sombre et de cramoisi vif — un thème sombre exécutif qui inspire la détermination",
  "Description.ru": "Смелый контраст тёмно-серого и яркого алого — строгая тёмная тема, внушающая решительность",
  "Description.pt": "Um contraste ousado de cinza escuro e carmesim vívido — um tema escuro executivo que inspira determinação",
  "Author": "K.AKASAKA",
  "Category": "Premium",

  // ── 基本 UI 要素（フォームとテキストの境界を明確化） ──
  "Base": {
    "BackgroundColor": "#212121",                      // メイン背景色：重厚なダークグレー
