{
  "Description.ja": "\u6DE1\u3044\u30E9\u30D9\u30F3\u30C0\u30FC\u306E\u4F5C\u696D\u9762\u306B\u30B7\u30A2\u30F3\u00D7\u30DE\u30BC\u30F3\u30BF\u306E\u30EC\u30C8\u30ED\u30FB\u30C7\u30E5\u30AA\u304C\u8E0A\u308B\u3001\u30D1\u30B9\u30C6\u30EB\u30FB\u30F4\u30A7\u30A4\u30D1\u30FC\u30A6\u30A7\u30FC\u30D6",
