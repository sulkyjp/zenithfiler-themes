{
  "Description.ja": "\u674F\u8272\u306E\u30D4\u30FC\u30C1\u30AF\u30EA\u30FC\u30E0\u306B\u30C6\u30E9\u30B3\u30C3\u30BF\u304C\u6620\u3048\u308B\u3001\u5348\u5F8C\u306E\u967D\u3060\u307E\u308A\u306E\u3088\u3046\u306A\u30C6\u30FC\u30DE",
