{
  "Description.ja": "\u935B\u9244\u3092\u601D\u308F\u305B\u308B\u30D6\u30EB\u30FC\u30B0\u30EC\u30FC\u306E\u6697\u8272\u306B\u3001\u4F4E\u5F69\u5EA6\u306E\u30B9\u30C1\u30FC\u30EB\u30D6\u30EB\u30FC\u304C\u9759\u304B\u306B\u5BBF\u308B\u30C6\u30FC\u30DE",
  "Description.en": "A wrought iron-inspired dark blue-gray theme with muted steel blue quietly settled within",
  "Description.zh-CN": "\u7075\u611F\u6E90\u81EA\u953B\u94C1\u7684\u6DF1\u84DD\u7070\u4E3B\u9898\uFF0C\u67D4\u548C\u7684\u94A2\u84DD\u8272\u9759\u9759\u6C89\u6DC0\u5176\u4E2D",
  "Description.zh-TW": "\u9748\u611F\u6E90\u81EA\u935B\u9435\u7684\u6DF1\u85CD\u7070\u4E3B\u984C\uFF0C\u67D4\u548C\u7684\u92FC\u85CD\u8272\u975C\u975C\u6C89\u6FB1\u5176\u4E2D",
  "Description.ko-KR": "\uB2E8\uCCA0\uC5D0\uC11C \uC601\uAC10\uC744 \uBC1B\uC740 \uB2E4\uD06C \uBE14\uB8E8\uADF8\uB808\uC774 \uD14C\uB9C8, \uCC28\uBD84\uD55C \uC2A4\uD2F8 \uBE14\uB8E8\uAC00 \uC870\uC6A9\uD788 \uAE43\uB4E0",
