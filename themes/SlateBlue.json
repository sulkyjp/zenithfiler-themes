    "FocusedPaneHeaderBackgroundColor": "#252D3A",     // フォーカス中ヘッダー
    "OnePointDarkColor": "#569CD6",
    "OnePointDarkTextColor": "#FFFFFF",                    // アクセントのブルー帯
    "TabSeparatorColor": "#506175",                    // タブ区切り
    "TabHoverColor": "#252D3A",                        // タブホバー
    "ToolbarSeparatorColor": "#6A737D",                // ツールバーセパレーター
    "TreeLineColor": "#3A4556",                         // ツリービュー接続線
    "PopupBackgroundColor": "#1E2530",                 // フローティングポップアップの背景色
    "PopupTextColor": "#E1E8F0",                       // ポップアップ内のテキスト色
    "PopupHoverBackgroundColor": "#324156",            // ポップアップリスト項目のホバー背景色
    "PopupHoverTextColor": "#E1E8F0"                   // ポップアップリスト項目のホバーテキスト色
  },

  // ── リスト・選択・ボタン（リカバリボタンの視認性を劇的改善） ──
  "List": {
    "ListHoverColor": "#252D3A",                       // リスト項目ホバー
    "SelectionColor": "#264F78",                       // リスト項目選択
