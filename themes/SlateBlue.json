{
  // ============================================================
  //  Zenith Filer Theme Configuration: SlateBlue (Professional)
  //  コンセプト：深夜のオフィスに漂う静寂と、精密な情報処理の融合
  //  ブラッシュアップ：フォームの境界確定、ボタンの立体感、履歴の可読性向上
  // ============================================================

  "Description.ja": "深夜のオフィスのような静寂と、高度な情報処理をイメージした濃紺",
  "Description.en": "A deep navy evoking the silence of a late-night office and advanced information processing",
  "Description.zh-CN": "深邃藏青色，唤起深夜办公室的寂静与高级信息处理的氛围",
  "Description.zh-TW": "深邃藏青色，喚起深夜辦公室的寂靜與高級資訊處理的氛圍",
  "Description.ko-KR": "심야 사무실의 정적과 고급 정보 처리를 연상시키는 깊은 네이비",
  "Description.de": "Ein tiefes Navy, das die Stille eines Büros bei Nacht und fortgeschrittene Datenverarbeitung hervorruft",
  "Description.es": "Un azul marino profundo que evoca el silencio de una oficina nocturna y el procesamiento avanzado de información",
  "Description.fr": "Un bleu marine profond évoquant le silence d'un bureau de nuit et le traitement avancé de l'information",
  "Description.ru": "Глубокий тёмно-синий, вызывающий тишину ночного офиса и атмосферу обработки данных",
  "Description.pt": "Um azul-marinho profundo que evoca o silêncio de um escritório noturno e o processamento avançado de informações",
  "Author": "K.AKASAKA",
  "Category": "Professional",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#151B24",                      // メイン背景：深みのあるスレートネイビー
    "SidebarColor": "#1E2530",                         // サイドバー：操作エリアとの境界を定義
    "HeaderColor": "#0D1219",                          // アドレスバー・タブ背景：一段深く沈ませて集中力を高める
    "TitleBarColor": "#252D3A",                        // タイトルバー背景
    "TitleBarTextColor": "#E1E8F0",                    // タイトルバーの文字・ボタン色
