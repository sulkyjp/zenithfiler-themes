{
  "Description.ja": "\u512A\u96C5\u306A\u30E9\u30D9\u30F3\u30C0\u30FC\u3068\u30DF\u30B9\u30C6\u30A3\u30B0\u30EC\u30FC\u304C\u7E54\u308A\u306A\u3059\u3001\u4E0A\u54C1\u3067\u843D\u3061\u7740\u3044\u305F\u30D5\u30A7\u30DF\u30CB\u30F3\u30FB\u30B9\u30BF\u30A4\u30EB",
