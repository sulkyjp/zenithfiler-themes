{
  "Description.ja": "\u548C\u3092\u611F\u3058\u3055\u305B\u308B\u67D4\u3089\u304B\u306A\u30D4\u30F3\u30AF\u3068\u767D\u306E\u3001\u5FC3\u843D\u3061\u7740\u304F\u30A8\u30EC\u30AC\u30F3\u30C8\u306A\u914D\u8272",
