  "Description.zh-TW": "\u7D2B\u5916\u5149\u5728\u9ED1\u6697\u4E2D\u6F02\u6D6E\u7684\u5FA9\u53E4\u4E3B\u984C\uFF0C\u5F77\u5F7F\u88AB\u9ED1\u5149\u71C8\u7167\u4EAE",
  "Description.ko-KR": "\uBE14\uB799\uB77C\uC774\uD2B8\uC5D0 \uBE44\uCDB0\uC9C4 \uB4EF \uC5B4\uB460 \uC18D\uC5D0 \uC790\uC678\uC120 \uBE5B\uC774 \uB5A0\uB2E4\uB2C8\uB294 \uB808\uD2B8\uB85C \uD14C\uB9C8",
