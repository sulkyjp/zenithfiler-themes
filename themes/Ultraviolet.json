{
  "Description.ja": "\u30D6\u30E9\u30C3\u30AF\u30E9\u30A4\u30C8\u306B\u7167\u3089\u3055\u308C\u305F\u3088\u3046\u306A\u3001\u7D2B\u5916\u7DDA\u306E\u5149\u304C\u95C7\u306B\u6D6E\u304B\u3076\u30EC\u30C8\u30ED\u30C6\u30FC\u30DE",
